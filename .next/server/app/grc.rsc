ull,{"className":"cert-row","children":[["$","span",null,{"className":"cert star","children":"CISM — Certified Information Security Manager"}],["$","span",null,{"className":"cert star","children":"CCSP — Certified Cloud Security Professional"}],["$","span",null,{"className":"cert","children":"CGEIT — Governance of Enterprise IT"}],["$","span",null,{"className":"cert","children":"CRISC — Risk and Information Systems Control"}],["$","span",null,{"className":"cert","children":"CDPSE — Data Privacy Solutions Engineer"}],["$","span",null,{"className":"cert","children":"BCI Certificate in Business Continuity"}]]}]]}]]}],["$","div",null,{"className":"phase p5","children":[["$","div",null,{"className":"phase-left","children":[["$","div",null,{"className":"phase-marker"}],["$","span",null,{"className":"phase-num","children":"Phase 05"}],["$","span",null,{"className":"phase-title","children":["Job Ready &",["$","br",null,{}],"Portfolio Built"]}],["$","span",null,{"className":"phase-duration","children":"13 – 18 Months"}]]}],["$","div",null,{"className":"phase-right","children":[["$","p",null,{"className":"phase-desc","children":"GRC roles demand evidence of process thinking, not just theoretical knowledge. Build artefacts that demonstrate you can actually do the job. Your portfolio should show a gap assessment, a risk register, a policy document, and ideally a mock audit report. These become your interview talking points."}],["$","div",null,{"className":"topic-cols","children":[["$","div",null,{"className":"topic-box","children":[["$","div",null,{"className":"topic-box-label","children":"Portfolio Artefacts to Build"}],["$","ul",null,{"className":"topic-items","children":[["$","li",null,{"children":"ISO 27001 gap assessment for a fictitious cloud SaaS company"}],["$","li",null,{"children":"SOC 2 readiness checklist with cloud control mappings"}],["$","li",null,{"children":"Risk register template with 10+ realistic cloud risks assessed"}],["$","li",null,{"children":"Cloud security policy pack (IS policy, access control, encryption)"}],["$","li",null,{"children":"DPIA template for a cloud-hosted HR system"}],["$","li",null,{"children":"Mock board-level risk report (1-pager format)"}]]}]]}],["$","div",null,{"className":"topic-box","children":[["$","div",null,{"className":"topic-box-label","children":"Interview Preparation"}],["$","ul",null,{"className":"topic-items","children":[["$","li",null,{"children":"\"Walk me through an ISO 27001 implementation you'd lead\""}],["$","li",null,{"children":"\"How would you scope a SOC 2 for a cloud-native startup?\""}],["$","li",null,{"children":"\"How do you explain a high risk to a board that wants to accept it?\""}],["$","li",null,{"children":"\"What controls map to GDPR Article 32?\""}],["$","li",null,{"children":"\"We have a new AWS account — what's your first 30 days?\""}],["$","li",null,{"children":"Know your cert content cold — interviewers will probe"}]]}]]}],["$","div",null,{"className":"topic-box","children":[["$","div",null,{"className":"topic-box-label","children":"Visibility & Network"}],["$","ul",null,{"className":"topic-items","children":[["$","li",null,{"children":"LinkedIn: document your framework learning journey"}],["$","li",null,{"children":"Publish a \"GRC in AWS\" or \"ISO 27001 for startups\" blog post"}],["$","li",null,{"children":"Join ISACA, (ISC)², IAPP chapters in your region"}],["$","li",null,{"children":"Attend BSides, ISACA conferences, CSA events"}],["$","li",null,{"children":"Volunteer: help a small charity or NGO with their GRC basics"}]]}]]}]]}]]}]]}]]}],["$","section",null,{"className":"frameworks-section","children":[["$","div",null,{"className":"sec-header","children":[["$","span",null,{"className":"sec-label","children":"Key Compliance Frameworks"}],["$","div",null,{"className":"sec-rule"}],["$","span",null,{"className":"sec-num","children":"02 / 06"}]]}],["$","div",null,{"className":"fw-grid","children":[["$","div","ISO 27001",{"className":"fw-card","children":[["$","span",null,{"className":"fw-tag mandatory","children":"Mandatory Know"}],["$","div",null,{"className":"fw-name","children":"ISO 27001"}],["$","div",null,{"className":"fw-full","children":"International Standard for Information Security Management Systems"}],["$","div",null,{"className":"fw-desc","children":"The global gold standard. Requires building a formal ISMS with documented risk treatment. Popular in UK, EU, and global enterprise supply chains. Certification requires a third-party audit by an accredited body."}],["$","div",null,{"className":"fw-when","children":[["$","strong",null,{"children":"When you'll use it:"}]," ","Any enterprise GRC role, consultancy, supply chain compliance, vendor assessments"]}]]}],["$","div","SOC 2",{"className":"fw-card","children":[["$","span",null,{"className":"fw-tag mandatory","children":"Mandatory Know"}],["$","div",null,{"className":"fw-name","children":"SOC 2"}],["$","div",null,{"className":"fw-full","children":"System and Organisation Controls — Trust Services Criteria"}],["$","div",null,{"className":"fw-desc","children":"US-origin but globally adopted for SaaS and cloud providers. Customers demand SOC 2 Type II reports as proof of controls. Uses Trust Services Criteria: Security, Availability, Confidentiality, Privacy, Processing Integrity."}],["$","div",null,{"className":"fw-when","children":[["$","strong",null,{"children":"When you'll use it:"}]," ","Tech companies, SaaS startups, any org serving US enterprise customers"]}]]}],["$","div","GDPR",{"className":"fw-card","children":[["$","span",null,{"className":"fw-tag mandatory","children":"Mandatory Know"}],["$","div",null,{"className":"fw-name","children":"GDPR"}],["$","div",null,{"className":"fw-full","children":"General Data Protection Regulation (EU/UK)"}],["$","div",null,{"className":"fw-desc","children":"Non-negotiable for any org handling EU/UK personal data. Fines up to 4% global turnover. Requires lawful basis for processing, privacy by design, breach reporting within 72 hours, and DPIAs for high-risk processing."}],["$","div",null,{"className":"fw-when","children":[["$","strong",null,{"children":"When you'll use it:"}]," ","Every role in the UK and EU. Also matters for US orgs serving EU customers"]}]]}],["$","div","NIST CSF",{"className":"fw-card","children":[["$","span",null,{"className":"fw-tag common","children":"Very Common"}],["$","div",null,{"className":"fw-name","children":"NIST CSF"}],["$","div",null,{"className":"fw-full","children":"NIST Cybersecurity Framework 2.0"}],["$","div",null,{"className":"fw-desc","children":"US-originated but globally used as a maturity and gap assessment tool. The 6-function structure (Govern, Identify, Protect, Detect, Respond, Recover) maps well onto cloud environments and is board-friendly language."}],["$","div",null,{"className":"fw-when","children":[["$","strong",null,{"children":"When you'll use it:"}]," ","US companies, FedRAMP, maturity assessments, board reporting"]}]]}],["$","div","PCI DSS",{"className":"fw-card","children":[["$","span",null,{"className":"fw-tag common","children":"Very Common"}],["$","div",null,{"className":"fw-name","children":"PCI DSS"}],["$","div",null,{"className":"fw-full","children":"Payment Card Industry Data Security Standard v4.0"}],["$","div",null,{"className":"fw-desc","children":"Mandatory for any org that stores, processes, or transmits cardholder data. 12 requirements covering network security, access control, monitoring, and testing. Cloud scope analysis (CDE) is complex and highly valued."}],["$","div",null,{"className":"fw-when","children":[["$","strong",null,{"children":"When you'll use it:"}]," ","E-commerce, fintech, retail, payment processors"]}]]}],["$","div","CIS Controls",{"className":"fw-card","children":[["$","span",null,{"className":"fw-tag common","children":"Very Common"}],["$","div",null,{"className":"fw-name","children":"CIS Controls"}],["$","div",null,{"className":"fw-full","children":"Center for Internet Security Controls v8"}],["$","div",null,{"className":"fw-desc","children":"18 prioritised security controls with cloud-specific Implementation Groups. Practical, prescriptive, and widely used as a baseline hardening standard. Strong overlap with ISO 27001 Annex A and SOC 2 criteria."}],["$","div",null,{"className":"fw-when","children":[["$","strong",null,{"children":"When you'll use it:"}]," ","Hardening assessments, gap analysis baseline, cyber insurance requirements"]}]]}],["$","div","HIPAA",{"className":"fw-card","children":[["$","span",null,{"className":"fw-tag sector","children":"Sector-Specific"}],["$","div",null,{"className":"fw-name","children":"HIPAA"}],["$","div",null,{"className":"fw-full","children":"Health Insurance Portability and Accountability Act (US)"}],["$","div",null,{"className":"fw-desc","children":"US federal law governing Protected Health Information (PHI). Technical, administrative, and physical safeguards. Cloud providers must sign Business Associate Agreements (BAAs). AWS, Azure, GCP all offer HIPAA-eligible services."}],["$","div",null,{"className":"fw-when","children":[["$","strong",null,{"children":"When you'll use it:"}]," ","Healthcare, health-tech, clinical research, insurance"]}]]}],["$","div","DORA",{"className":"fw-card","children":[["$","span",null,{"className":"fw-tag sector","children":"Sector-Specific"}],["$","div",null,{"className":"fw-name","children":"DORA"}],["$","div",null,{"className":"fw-full","children":"Digital Operational Resilience Act (EU Financial Sector)"}],["$","div",null,{"className":"fw-desc","children":"EU regulation effective Jan 2025 for financial entities and their ICT providers. Covers ICT risk management, incident reporting, resilience testing (TLPT), and third-party risk. Cloud providers to financial firms fall within scope."}],["$","div",null,{"className":"fw-when","children":[["$","strong",null,{"children":"When you'll use it:"}]," ","Banks, insurers, investment firms, fintech in EU/UK"]}]]}],["$","div","NIS2",{"cl