se-right","children":[["$","p",null,{"className":"phase-desc","children":"Frameworks are your primary toolkit. You'll spend much of your GRC career living inside these documents. Don't just skim them — read the actual standards, understand the intent behind controls, and start mentally mapping them against real cloud environments. This is what separates a great GRC practitioner from a checkbox monkey."}],["$","div",null,{"className":"topic-cols","children":[["$","div",null,{"className":"topic-box","children":[["$","div",null,{"className":"topic-box-label","children":"ISO 27001 / 27002"}],["$","ul",null,{"className":"topic-items","children":[["$","li",null,{"children":"ISMS scope, context, interested parties (Clause 4)"}],["$","li",null,{"children":"Leadership and risk treatment (Clauses 5–8)"}],["$","li",null,{"children":"Annex A controls — all 93, know the key ones cold"}],["$","li",null,{"children":"Statement of Applicability (SoA) writing"}],["$","li",null,{"children":"Certification audit process: Stage 1, Stage 2"}],["$","li",null,{"children":"Continual improvement (Clause 10) and NCRs"}]]}]]}],["$","div",null,{"className":"topic-box","children":[["$","div",null,{"className":"topic-box-label","children":"NIST CSF & SP 800-53"}],["$","ul",null,{"className":"topic-items","children":[["$","li",null,{"children":"CSF 2.0: Govern, Identify, Protect, Detect, Respond, Recover"}],["$","li",null,{"children":"Current Profiles vs Target Profiles"}],["$","li",null,{"children":"SP 800-53 control families (AC, AU, CM, IA, SC, SI)"}],["$","li",null,{"children":"FedRAMP: US federal cloud compliance"}],["$","li",null,{"children":"NIST RMF: 7-step risk management framework"}]]}]]}],["$","div",null,{"className":"topic-box","children":[["$","div",null,{"className":"topic-box-label","children":"SOC 2 (Type I & II)"}],["$","ul",null,{"className":"topic-items","children":[["$","li",null,{"children":"Trust Services Criteria (Security, Availability, Confidentiality, Privacy, PI)"}],["$",