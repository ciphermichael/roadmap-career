ecurity Basics"}],["$","ul",null,{"className":"topic-list","children":[["$","li",null,{"children":"CIA Triad: Confidentiality, Integrity, Availability"}],["$","li",null,{"children":"Authentication vs Authorisation"}],["$","li",null,{"children":"Encryption fundamentals (symmetric, asymmetric, hashing)"}],["$","li",null,{"children":"PKI, certificates, CAs"}],["$","li",null,{"children":"OWASP Top 10 awareness"}],["$","li",null,{"children":"Vulnerability vs threat vs risk"}]]}]]}],["$","div",null,{"className":"topic-group","children":[["$","div",null,{"className":"topic-group-label","style":{"color":"var(--accent-cyan)"},"children":"Programming & Scripting"}],["$","ul",null,{"className":"topic-list","children":[["$","li",null,{"children":"Python — loops, functions, APIs, file I/O"}],["$","li",null,{"children":"Bash scripting for automation"}],["$","li",null,{"children":"JSON & YAML fluency"}],["$","li",null,{"children":"Git basics (clone, commit, push, branches)"}],["$","li",null,{"children":"REST APIs — how to call them, read responses"}]]}]]}]]}],["$","div",null,{"className":"certs","children":[["$","span",null,{"className":"cert-chip priority","children":"CompTIA Security+"}],["$","span",null,{"className":"cert-chip priority","children":"CompTIA Network+"}],["$","span",null,{"className":"cert-chip","children":"Google IT Support Certificate"}]]}]]}]]}],["$","div",null,{"className":"phase phase-2","children":[["$","div",null,{"className":"phase-sidebar","children":[["$","span",null,{"className":"phase-number","children":"PHASE 02"}],["$","span",null,{"className":"phase-title","children":"CLOUD CORE"}],["$","span",null,{"className":"phase-duration","children":"3 – 6 Months"}]]}],["$","div",null,{"className":"phase-body","children":[["$","p",null,{"className":"phase-desc","children":"Get your hands dirty with cloud infrastructure. Start with ONE cloud (AWS recommended — largest market share), get comfortable, then cross-train. Learn how cloud is architected: compute, sto